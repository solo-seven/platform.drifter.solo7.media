{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://solo7.platform/schemas/rule.schema.json",
  "title": "GameRule",
  "type": "object",
  "required": ["id", "triggers", "conditions", "actions", "priority"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "priority": { "type": "integer" },
    "triggers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/EventTrigger" }
    },
    "conditions": {
      "type": "array",
      "items": { "$ref": "#/definitions/Condition" }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Action" }
    }
  },
  "definitions": {
    "EventTrigger": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "condition": { "type": "object" }
      },
      "additionalProperties": false
    },
    "Condition": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["expression", "property", "compare"] },
        "property": { "type": "string" },
        "operator": { "type": "string" },
        "value": {},
        "expression": { "type": "string" }
      },
      "additionalProperties": true
    },
    "Action": {
      "type": "object",
      "required": ["type", "target"],
      "properties": {
        "type": { "type": "string" },
        "target": { "type": "string" },
        "properties": { "type": "object" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
